  "panels": [
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Requests P99 Latency (ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[5m])) * 1000",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    }
  ],
